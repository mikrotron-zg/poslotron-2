<?xml version="1.0" encoding="UTF-8"?>
<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Site-Conf" xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">
    <include location="component://common/webcommon/WEB-INF/common-controller.xml"/>
    <include location="component://commonext/webapp/WEB-INF/controller.xml"/>

    <description>Fiscal Manager Site Configuration File</description>

    <!-- Request Mappings -->
    <request-map uri="view">
        <security https="true" auth="false"/>
        <response name="success" type="request" value="main"/>
    </request-map>

    <request-map uri="main">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="main"/>
    </request-map>

    <request-map uri="FindFiscalInvoice">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="FindFiscalInvoice"/>
    </request-map>

    <request-map uri="payment">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="payment"/>
    </request-map>

    <request-map uri="FindFiscalInvoicePayment">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="FindFiscalInvoicePayment"/>
    </request-map>

    <request-map uri="updateFiscalInvoiceIsPayed">
        <security https="true" auth="true"/>
        <event type="service" invoke="updateFiscalInvoiceIsPayed"/>
        <response name="success" type="view" value="FindFiscalInvoicePayment"/>
        <response name="error" type="view" value="FindFiscalInvoicePayment"/>
    </request-map>

    <request-map uri="LookupPartyName"><security auth="true" https="true"/><response name="success" type="view" value="LookupPartyName"/></request-map>

    <!-- View Mappings -->
    <view-map name="main" type="screen" page="component://fiscal/widget/CommonScreens.xml#main"/>
    <view-map name="FindFiscalInvoice" type="screen" page="component://fiscal/widget/CommonScreens.xml#FindFiscalInvoice"/>
    <view-map name="payment" type="screen" page="component://fiscal/widget/CommonScreens.xml#payment"/>
    <view-map name="FindFiscalInvoicePayment" type="screen" page="component://fiscal/widget/CommonScreens.xml#FindFiscalInvoicePayment"/>
    <view-map name="LookupPartyName" type="screen" page="component://party/widget/partymgr/LookupScreens.xml#LookupPartyName"/>

</site-conf>
