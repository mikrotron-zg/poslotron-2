<?xml version="1.0" encoding="UTF-8"?>
<forms xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Form" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Form http://ofbiz.apache.org/dtds/widget-form.xsd">
    <form name="FindFiscalInvoice" type="single" target="FindFiscalInvoice">
        <field name="noConditionFind"><hidden value="Y"/></field>
        <field name="fiscalInvoiceDate" title="${uiLabelMap.FiscalInvoiceDate}">
            <date-find type="date"/>
        </field>
        <field name="fiscalInvoiceNumber" title="${uiLabelMap.FiscalInvoiceNumber}">
            <text-find/>
        </field>
        <field name="partyId" title="${uiLabelMap.FiscalInvoiceRecipientPartyId}">
            <lookup target-form-name="LookupPartyName" size="15"/>
        </field>
        <field name="fiscalStoreId" title="${uiLabelMap.FiscalStoreId}">
            <drop-down allow-empty="true">
                <entity-options entity-name="FiscalStore" key-field-name="fiscalStoreId" description="${fiscalStoreLabel} [${fiscalStoreId}]">
                    <entity-order-by field-name="fiscalStoreLabel"/>
                </entity-options>
            </drop-down>
        </field>
        <field name="fiscalPaymentTerminalLabel" title="${uiLabelMap.FiscalPaymentTerminalLabel}">
            <text-find/>
        </field>
        <field name="fiscalInvoiceTypeId" title="${uiLabelMap.FiscalInvoiceType}">
            <drop-down allow-empty="true">
                <entity-options entity-name="FiscalInvoiceType" key-field-name="fiscalInvoiceTypeId" description="${description} [${fiscalInvoiceTypeId}]">
                    <entity-order-by field-name="description"/>
                </entity-options>
            </drop-down>
        </field>
        <field name="searchButton" title="${uiLabelMap.CommonFind}" widget-style="smallSubmit">
            <submit button-type="button"/>
        </field>
    </form>
</forms>
