<!--
    Poslotron extensions for the Catalog Manager (catalog) webapp.
    Screens here are mounted via Catalog's controller include and rendered
    inside Catalog Manager's standard chrome (main-decorator from
    component://product/widget/catalog/CommonScreens.xml).
-->
<screens xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Screen" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Screen http://ofbiz.apache.org/dtds/widget-screen.xsd">

    <!--
        Quick-add product entry screen. Shows a minimal create form
        (internalName + productName) and assumes productTypeId = FINISHED_GOOD,
        which is hidden from the user. Submits to the standard createProduct
        request, so on success the user lands on EditProduct for the newly
        created product.
    -->
    <screen name="quickAddProduct">
        <section>
            <actions>
                <set field="titleProperty" value="PoslotronProductQuickAdd"/>
                <set field="headerItem" value="products"/>
                <!--
                    Lift the batch-import service's OUT param from the
                    `parameters` map (where ServiceEventHandler placed it
                    as a request attribute, then ScreenRenderer rolled it
                    up via UtilHttp.getCombinedMap) onto the screen
                    context so both the conditional below and the grid's
                    list-name="createdProducts" can see it directly.
                -->
                <set field="createdProducts" from-field="parameters.createdProducts"/>
            </actions>
            <widgets>
                <decorator-screen name="main-decorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <section>
                            <condition>
                                <if-has-permission permission="CATALOG" action="_CREATE"/>
                            </condition>
                            <widgets>
                                <screenlet title="${uiLabelMap.PoslotronProductQuickAdd}">
                                    <include-form name="QuickAddProduct" location="component://poslotron/widget/CatalogAppExtForms.xml"/>
                                    <!--
                                        Inline JS attached after the form so the inputs already exist
                                        in the DOM. Hides the productName row when the "same as internal
                                        name" checkbox is ticked and mirrors internalName into the
                                        hidden productName input on every keystroke and on submit.
                                    -->
                                    <platform-specific>
                                        <html><html-template location="component://poslotron/template/QuickAddProductScript.ftl"/></html>
                                    </platform-specific>
                                </screenlet>
                                <!--
                                    Batch CSV import. Errors raised by the import service flow
                                    through the standard OFBiz error channel and are rendered by
                                    the application decorator at the top of the page.
                                -->
                                <screenlet title="${uiLabelMap.PoslotronBatchAddProducts}">
                                    <include-form name="BatchCreateProductsCsv" location="component://poslotron/widget/CatalogAppExtForms.xml"/>
                                </screenlet>
                                <!--
                                    Results grid. Only shown after a successful batch import
                                    (when the service has populated the createdProducts list).
                                -->
                                <section>
                                    <condition>
                                        <not><if-empty field="createdProducts"/></not>
                                    </condition>
                                    <widgets>
                                        <screenlet title="${uiLabelMap.PoslotronBatchAddProductsResult}">
                                            <include-grid name="BatchCreateProductsResult" location="component://poslotron/widget/CatalogAppExtForms.xml"/>
                                        </screenlet>
                                    </widgets>
                                </section>
                            </widgets>
                            <fail-widgets>
                                <label style="h3" text="${uiLabelMap.ProductCatalogViewPermissionError}"/>
                            </fail-widgets>
                        </section>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

</screens>
