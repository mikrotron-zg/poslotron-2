<!--
    Poslotron extensions for the Party Manager (partymgr) webapp.
    Screens here are mounted via Party's controller include and rendered
    inside Party Manager's standard chrome (main-decorator from
    component://party/widget/partymgr/CommonScreens.xml).
-->
<screens xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Screen" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Screen http://ofbiz.apache.org/dtds/widget-screen.xsd">

    <!--
        Suppliers landing screen. Suppliers are PartyGroups whose main role is
        SUPPLIER. The slimmed-down LookupSupplier form has just partyId and
        groupName inputs (both optional); ListSupplier loads its rows from
        the PartyRoleAndPartyDetail view entity via FindSuppliers.groovy,
        ordered by groupName ascending.
    -->
    <screen name="findSuppliers">
        <section>
            <actions>
                <set field="titleProperty" value="PoslotronPartySuppliers"/>
                <set field="headerItem" value="suppliers"/>
                <set field="tabButtonItem" value="findparty"/>
                <set field="helpAnchor" value="_help_for_the_party_find_screen"/>
            </actions>
            <widgets>
                <decorator-screen name="main-decorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <section>
                            <condition>
                                <if-service-permission service-name="partyBasePermissionCheck" main-action="VIEW"/>
                            </condition>
                            <widgets>
                                <screenlet id="FindSuppliersPanel" title="${uiLabelMap.PoslotronPartySuppliers}"
                                           navigation-form-name="LookupSupplier"
                                           save-collapsed="false" collapsible="true" initially-collapsed="${initialyCollapsed}">
                                    <include-form name="LookupSupplier" location="component://poslotron/widget/PartyAppExtForms.xml"/>
                                </screenlet>
                                <screenlet title="${uiLabelMap.CommonSearchResults}" navigation-form-name="ListSupplier">
                                    <include-grid name="ListSupplier" location="component://poslotron/widget/PartyAppExtForms.xml"/>
                                </screenlet>
                            </widgets>
                            <fail-widgets>
                                <label style="h3" text="${uiLabelMap.PartyMgrViewPermissionError}"/>
                            </fail-widgets>
                        </section>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

</screens>
