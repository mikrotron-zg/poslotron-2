<!--
    Poslotron extensions: Forms used by the Catalog Manager screens added in
    CatalogAppExtScreens.xml.
-->
<forms xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Form" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Form http://ofbiz.apache.org/dtds/widget-form.xsd">

    <!--
        Minimal product entry form. Submits to the plugin's
        quickCreateProduct request, which runs the
        poslotronQuickCreateProduct wrapper service and then redirects to
        EditProduct for the new productId. The wrapper takes care of
        creating both the Product and (when a price was entered) the
        default EUR ProductPrice. The product type is fixed to
        FINISHED_GOOD via a hidden field; productId is left empty so the
        createProduct service auto-generates one.
    -->
    <form name="QuickAddProduct" type="single" target="quickCreateProduct" focus-field-name="internalName"
          header-row-style="header-row" default-table-style="basic-table">
        <actions>
            <!--
                Pre-check the "same as internal name" box on first render. Re-rendering
                after a server-side validation error keeps whatever value the user
                actually submitted (Y or empty) so the checkbox state survives a
                round-trip.
            -->
            <set field="useInternalAsName" from-field="parameters.useInternalAsName" default-value="Y"/>
        </actions>
        <field name="productTypeId"><hidden value="FINISHED_GOOD"/></field>
        <!--
            Suppress the post-create indexProductKeywords ECA in
            applications/product/entitydef/eecas.xml: the ECA only fires
            when Product.autoCreateKeywords != "N", so persisting "N"
            here keeps the Quick Add flow free of the keyword indexing
            round-trip. Keywords can still be (re)built later from the
            standard product screens.
        -->
        <field name="autoCreateKeywords"><hidden value="N"/></field>
        <!--
            Weight is captured once and stored against both productWeight
            and shippingWeight; weightUomId is fixed to WT_g so the user
            never has to pick a unit. The shippingWeight input is hidden
            and kept in sync with productWeight via JS (see the screen).
        -->
        <field name="weightUomId"><hidden value="WT_g"/></field>
        <field name="internalName" title="${uiLabelMap.ProductInternalName}" required-field="true">
            <text size="30" maxlength="255"/>
        </field>
        <field name="useInternalAsName" title="${uiLabelMap.PoslotronProductNameSameAsInternal}">
            <check></check>
        </field>
        <field name="productName" title="${uiLabelMap.ProductProductName}">
            <text size="30" maxlength="255"/>
        </field>
        <field name="productWeight" title="${uiLabelMap.PoslotronProductWeightInGrams}"
               tooltip="${uiLabelMap.PoslotronProductWeightInGramsHint}">
            <text size="10" maxlength="20" default-value="15"/>
        </field>
        <field name="shippingWeight"><hidden/></field>
        <!--
            Optional sale price. When non-empty, the wrapper service
            poslotronQuickCreateProduct creates a matching ProductPrice
            row (DEFAULT_PRICE / PURCHASE / EUR / _NA_ / taxInPrice=Y)
            with fromDate=now.
        -->
        <field name="price" title="${uiLabelMap.PoslotronProductPriceEur}"
               tooltip="${uiLabelMap.PoslotronProductPriceEurHint}">
            <text size="10" maxlength="20"/>
        </field>
        <!--
            Optional KPD/CPA classification code. When non-empty, the
            wrapper service creates a GoodIdentification row with
            goodIdentificationTypeId=KPD_CPA tied to the new product.
        -->
        <field name="idValue" title="KPD/CPA">
            <text size="20" maxlength="60" default-value="46.50.22"/>
        </field>
        <field name="submitButton" title="${uiLabelMap.CommonCreate}" widget-style="smallSubmit"><submit button-type="button"/></field>
    </form>

    <!--
        Batch CSV upload form. type="upload" makes the form widget render
        with enctype="multipart/form-data" so OFBiz's multipart handler
        decodes the bytes into the service's `uploadedFile` ByteBuffer.
    -->
    <form name="BatchCreateProductsCsv" type="upload" target="batchCreateProductsCsv"
          header-row-style="header-row" default-table-style="basic-table">
        <field name="uploadedFile" title="${uiLabelMap.PoslotronBatchCsvFile}"
               tooltip="${uiLabelMap.PoslotronBatchAddProductsHint}" required-field="true">
            <file size="40"/>
        </field>
        <field name="submitButton" title="${uiLabelMap.CommonUpload}" widget-style="smallSubmit"><submit button-type="button"/></field>
    </form>

    <!--
        Result grid for the batch import. Bound to the createdProducts
        list returned by the service (set as a request attribute via
        the OUT mode declaration on the service definition). The
        productId column is rendered as a button-styled hyperlink that
        opens EditProduct for that product.

        paginate="false" is intentional: the createdProducts list only
        lives in the request that responded to the multipart upload,
        so any pagination link would re-issue a plain GET to
        batchCreateProductsCsv without `uploadedFile` and trip the
        service-validation error. The dataset is bounded by a single
        transaction's worth of rows, so rendering them all in one go
        is the practical choice.
    -->
    <grid name="BatchCreateProductsResult" list-name="createdProducts" paginate="false"
          header-row-style="header-row" default-table-style="basic-table">
        <field name="productId" title="${uiLabelMap.ProductProductId}">
            <!--
                smallSubmit is a tomahawk theme class explicitly meant
                to decorate plain <a> elements so they render with the
                same chrome as a form submit button (border, background,
                hover state). On <hyperlink> the attribute is `style`
                (link-style only exists on <sub-hyperlink>).
            -->
            <hyperlink description="${productId}" target="EditProduct" style="smallSubmit">
                <parameter param-name="productId"/>
            </hyperlink>
        </field>
        <field name="productName" title="${uiLabelMap.ProductProductName}"><display/></field>
        <field name="price" title="${uiLabelMap.PoslotronProductPriceEur}"><display type="currency" currency="EUR"/></field>
        <field name="idValue" title="KPD/CPA"><display/></field>
        <field name="productWeight" title="${uiLabelMap.PoslotronProductWeightInGrams}"><display/></field>
    </grid>

    <!--
        Warehouse status filter form. All fields are optional. productTypeId
        is constrained to physical "GOOD" subtypes and defaults to FINISHED_GOOD
        (the no-current-selected-key trick); every other field defaults to "any".

        The supplierPartyId drop-down carries a sentinel value "__NONE__" right
        after the empty (any) option so the user can ask for products that have
        no active SupplierProduct row. The follow-up groovy script
        (WarehouseStatus.groovy) interprets the sentinel.

        QOH filtering is split across two fields - the operator selector and
        the numeric value - because the result QOH is an aggregate (summed from
        InventoryItem) that we can't push into a SQL WHERE clause. The groovy
        script applies the comparison in memory.
    -->
    <form name="LookupWarehouseStatus" type="single" target="WarehouseStatus" focus-field-name="productId"
          header-row-style="header-row" default-table-style="basic-table">
        <!--
            Hidden marker so the groovy script can tell a real form submission
            apart from the initial GET on /catalog/control/WarehouseStatus.
            On a first load the script applies its own default for productTypeId
            (FINISHED_GOOD) - the form's no-current-selected-key only sets the
            display default, it never reaches the request when the form has
            not been submitted yet.
        -->
        <field name="searchSubmitted"><hidden value="Y"/></field>
        <field name="productId" title="${uiLabelMap.ProductProductId}">
            <lookup target-form-name="LookupProduct"/>
        </field>
        <!--
            Mirror the productTypeId drop-down used by EditProduct
            (ProductForms.xml#EditProduct): no entity-constraints, ordered by
            description. This way SERVICE, DIGITAL_GOOD, RAW_MATERIAL, ... all
            show up and the user can filter by any of them. FINISHED_GOOD is
            kept as the initial display default via no-current-selected-key.
        -->
        <field name="productTypeId" title="${uiLabelMap.ProductProductType}">
            <drop-down allow-empty="true" no-current-selected-key="FINISHED_GOOD">
                <entity-options entity-name="ProductType">
                    <entity-order-by field-name="description"/>
                </entity-options>
            </drop-down>
        </field>
        <field name="productCategoryId" title="${uiLabelMap.ProductCategory}">
            <lookup target-form-name="LookupProductCategory"/>
        </field>
        <field name="supplierPartyId" title="${uiLabelMap.PoslotronWarehouseStatusSupplier}">
            <drop-down allow-empty="true">
                <option key="__NONE__" description="${uiLabelMap.PoslotronWarehouseStatusNoSupplier}"/>
                <entity-options entity-name="PartyRoleAndPartyDetail" key-field-name="partyId" description="${groupName} [${partyId}]">
                    <entity-constraint name="roleTypeId" operator="equals" value="SUPPLIER"/>
                    <entity-constraint name="statusId" operator="equals" value="PARTY_ENABLED"/>
                    <entity-order-by field-name="groupName"/>
                </entity-options>
            </drop-down>
        </field>
        <field name="quantityOnHandOp" title="${uiLabelMap.PoslotronWarehouseStatusQohOperator}">
            <drop-down allow-empty="true">
                <option key="LT" description="${uiLabelMap.PoslotronWarehouseStatusOpLT}"/>
                <option key="LTE" description="${uiLabelMap.PoslotronWarehouseStatusOpLTE}"/>
                <option key="EQ" description="${uiLabelMap.PoslotronWarehouseStatusOpEQ}"/>
                <option key="GTE" description="${uiLabelMap.PoslotronWarehouseStatusOpGTE}"/>
                <option key="GT" description="${uiLabelMap.PoslotronWarehouseStatusOpGT}"/>
            </drop-down>
        </field>
        <field name="quantityOnHandValue" title="${uiLabelMap.PoslotronWarehouseStatusQohValue}">
            <text size="10" maxlength="20"/>
        </field>
        <field name="searchButton" widget-style="search"><submit/></field>
    </form>

    <!--
        Warehouse status result grid. Bound to the warehouseRows list built in
        WarehouseStatus.groovy. Default ordering (QOH ascending) is applied
        inside the script before the rows reach this widget; sort-field="true"
        on every column lets the user re-order interactively (the script also
        handles the sortField submit so pagination keeps the order across
        pages).

        lastPrice is rendered through display type="currency" with the per-row
        currency code (currencyUomId comes from SupplierProduct). This is the
        same pattern the fiscal plugin uses (see FiscalForms.xml#ListFiscalInvoice)
        and produces locale-aware output - e.g., "45,28 €" for hr_HR + EUR -
        instead of the raw BigDecimal.toString().
    -->
    <grid name="ListWarehouseStatus" list-name="warehouseRows"
          odd-row-style="alternate-row" header-row-style="header-row-2"
          default-table-style="basic-table hover-bar">
        <actions>
            <script location="component://poslotron/src/main/groovy/hr/mikrotron/poslotron/product/WarehouseStatus.groovy"/>
        </actions>
        <field name="productId" title="${uiLabelMap.ProductProductId}" sort-field="true" widget-style="buttontext">
            <hyperlink description="${productId}" target="EditProduct">
                <parameter param-name="productId"/>
            </hyperlink>
        </field>
        <field name="internalName" title="${uiLabelMap.ProductInternalName}" sort-field="true">
            <display description="${internalName}"/>
        </field>
        <field name="quantityOnHandTotal" title="${uiLabelMap.PoslotronWarehouseStatusQoh}" sort-field="true">
            <display description="${quantityOnHandTotal}"/>
        </field>
        <field name="availableToPromiseTotal" title="${uiLabelMap.PoslotronWarehouseStatusAtp}" sort-field="true">
            <display description="${availableToPromiseTotal}"/>
        </field>
        <field name="accountingQuantityTotal" title="${uiLabelMap.PoslotronWarehouseStatusAqt}" sort-field="true">
            <display description="${accountingQuantityTotal}"/>
        </field>
        <!--
            Supplier name rendered as a link to the supplier's primary web URL
            when one is on file (mirrors the ListSupplier grid). The HTML is
            built in WarehouseStatus.groovy with the URL + label HTML-encoded;
            encode-output="false" lets the anchor markup pass through. The
            field name remains "supplierName" so sort-field="true" sorts on
            the raw text rather than the rendered markup.
        -->
        <field name="supplierName" title="${uiLabelMap.PoslotronWarehouseStatusSupplier}" sort-field="true" encode-output="false">
            <display description="${supplierNameHtml}"/>
        </field>
        <!--
            Supplier's product id, rendered as a deep link when the supplier
            has a "catalog" web address on file. The base URL is any
            WEB_ADDRESS contact mech without a contactMechPurposeTypeId
            (PRIMARY_WEB_URL is intentionally excluded so the homepage and
            the catalog deep-link can coexist on the same supplier). The
            HTML is built in WarehouseStatus.groovy with both the URL and
            the visible text properly encoded; encode-output="false" lets
            the anchor markup pass through. Field name stays
            "supplierProductId" so the column sorts on the raw text.
        -->
        <field name="supplierProductId" title="${uiLabelMap.PoslotronWarehouseStatusSupplierProductId}" sort-field="true" encode-output="false">
            <display description="${supplierProductIdHtml}"/>
        </field>
        <field name="lastReceivedDate" title="${uiLabelMap.PoslotronWarehouseStatusLastReceived}" sort-field="true"
               widget-area-style="align-center" title-area-style="align-center">
            <display type="date"/>
        </field>
        <field name="lastPrice" title="${uiLabelMap.PoslotronWarehouseStatusLastPrice}" sort-field="true"
               widget-area-style="align-right" title-area-style="align-right">
            <display type="currency" currency="${currencyUomId}"/>
        </field>
    </grid>

    <!--
        Product deprecation result form. Bound to the deprecationRows list
        built in ProductDeprecation.groovy. Default ordering (AQT descending)
        is applied inside the script before the rows reach this widget;
        sort-field="true" on every column lets the user re-order interactively
        (the script also handles the sortField submit so pagination keeps the
        order across pages).

        type="multi" + use-row-submit="true" turns each row's _rowSubmit
        checkbox into the row-selection mechanism understood by OFBiz's
        multi-form helpers (UtilHttp.getMultiFormRowCount /
        getRowSubmitPrefix). The hidden productId travels via
        also-hidden="true" on the productId hyperlink so we get a
        productId_o_<N> companion field per row that the form post carries
        back to the controller event.

        target = the POST endpoint that runs the bulk deprecation event;
        paginate-target = the GET endpoint of this same screen so column
        sorting and pagination links stay on ProductDeprecation rather than
        re-issuing the deprecate-selected POST.

        No <submit/> field is declared in the form. The "Deprecate selected
        products" button is rendered above the table by the screen
        (CatalogAppExtScreens.xml) and uses the HTML5 form="..." attribute
        to submit this form by id; that way the call-to-action sits where
        the user expects it (above the data) without us fighting the
        form-widget renderer's footer-only submit placement.
    -->
    <form name="ListProductDeprecation" type="multi" use-row-submit="true"
          target="deprecateSelectedProducts" list-name="deprecationRows"
          paginate-target="ProductDeprecation"
          odd-row-style="alternate-row" header-row-style="header-row-2"
          default-table-style="basic-table hover-bar">
        <actions>
            <script location="component://poslotron/src/main/groovy/hr/mikrotron/poslotron/product/ProductDeprecation.groovy"/>
        </actions>
        <field name="productId" title="${uiLabelMap.ProductProductId}" sort-field="true" widget-style="buttontext">
            <hyperlink description="${productId}" target="EditProduct" also-hidden="true">
                <parameter param-name="productId"/>
            </hyperlink>
        </field>
        <field name="internalName" title="${uiLabelMap.ProductInternalName}" sort-field="true">
            <display description="${internalName}"/>
        </field>
        <field name="createdStamp" title="${uiLabelMap.FormFieldTitle_createdDate}" sort-field="true"
               widget-area-style="align-center" title-area-style="align-center">
            <display type="date"/>
        </field>
        <field name="accountingQuantityTotal" title="${uiLabelMap.PoslotronWarehouseStatusAqt}" sort-field="true">
            <display description="${accountingQuantityTotal}"/>
        </field>
        <field name="_rowSubmit" title="${uiLabelMap.CommonSelect}">
            <check/>
        </field>
        <field name="deprecateButton" title=" " widget-area-style="align-center" title-area-style="align-center" widget-style="smallSubmit" >
            <hyperlink description="${uiLabelMap.PoslotronDeprecateProduct}" target="deprecateProduct"
                       also-hidden="false">
                <parameter param-name="productId"/>
            </hyperlink>
        </field>
    </form>

</forms>
