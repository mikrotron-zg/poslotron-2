<!--
    Poslotron extensions for the Catalog Manager (catalog) webapp controller.

    This file is included from
        applications/product/webapp/catalog/WEB-INF/controller.xml
    via a single <include/> line, so that all our request- and view-maps
    extending the Catalog app live here in the plugin (not in core).
-->
<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Site-Conf"
        xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">

    <description>Poslotron extensions to Catalog Manager controller</description>

    <!-- ===== Quick add product ===== -->
    <request-map uri="quickAddProduct">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="quickAddProduct"/>
    </request-map>

    <!--
        Form submission target. Runs the wrapper service which creates the
        Product and (optionally) the default EUR price; on success we send
        the user straight to EditProduct for the new productId so they can
        carry on filling in details.
    -->
    <request-map uri="quickCreateProduct">
        <security https="true" auth="true"/>
        <event type="service" invoke="poslotronQuickCreateProduct"/>
        <response name="success" type="request-redirect" value="EditProduct"><redirect-parameter name="productId"/></response>
        <response name="error" type="view" value="quickAddProduct"/>
    </request-map>

    <!--
        Batch CSV import. Forward (type=view) to quickAddProduct so the
        request attributes set by the service (createdProducts, plus the
        standard error/event message lists on failure) survive into the
        rendered screen. A redirect would lose them.
    -->
    <request-map uri="batchCreateProductsCsv">
        <security https="true" auth="true"/>
        <event type="service" invoke="poslotronBatchCreateProductsCsv"/>
        <response name="success" type="view" value="quickAddProduct"/>
        <response name="error" type="view" value="quickAddProduct"/>
    </request-map>

    <view-map name="quickAddProduct" type="screen"
              page="component://poslotron/widget/CatalogAppExtScreens.xml#quickAddProduct"/>

    <!-- ===== Warehouse status ===== -->
    <!--
        Landing page for the global warehouse-status report (Stanje skladišta).
        Reached from the new ProductSubTabBar menu item; all filtering happens
        in the linked Groovy script.
    -->
    <request-map uri="WarehouseStatus">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="WarehouseStatus"/>
    </request-map>

    <view-map name="WarehouseStatus" type="screen"
              page="component://poslotron/widget/CatalogAppExtScreens.xml#warehouseStatus"/>

    <!-- ===== Product deprecation ===== -->
    <!--
        Landing page for the product-deprecation report (Zastara proizvoda).
        Reached from the new ProductSubTabBar menu item; all filtering is
        baked into the linked Groovy script (no user-facing search form).
    -->
    <request-map uri="ProductDeprecation">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="ProductDeprecation"/>
    </request-map>

    <view-map name="ProductDeprecation" type="screen"
              page="component://poslotron/widget/CatalogAppExtScreens.xml#productDeprecation"/>

    <!--
        POST target for the "Deprecate selected products" button. The form
        is a multi-form so the event handler decodes the per-row checkbox
        selection itself (see DeprecateSelectedProductsEvent.groovy) and
        delegates the actual write work to the
        poslotronDeprecateSelectedProducts service inside a single
        transaction.

        Success path: redirect back to ProductDeprecation so the user sees
        a refreshed grid (the just-deprecated products drop out of the
        result set because their salesDiscontinuationDate is no longer
        null) and the standard OFBiz event-message banner shows the
        "Deprecated N products." count. _EVENT_MESSAGE_ survives the
        redirect through the framework's session-promoted message channel.
    -->
    <!--
        Per-row "Deprecate" button. Accepts a single productId query
        parameter and reuses the same batch service with a one-element list.
        Always redirects back to ProductDeprecation so the grid refreshes.
    -->
    <request-map uri="deprecateProduct">
        <security https="true" auth="true"/>
        <event type="groovy"
               path="component://poslotron/src/main/groovy/hr/mikrotron/poslotron/product/DeprecateProductEvent.groovy"/>
        <response name="success" type="request-redirect" value="ProductDeprecation"/>
        <response name="error" type="request-redirect" value="ProductDeprecation"/>
    </request-map>

    <request-map uri="deprecateSelectedProducts">
        <security https="true" auth="true"/>
        <event type="groovy"
               path="component://poslotron/src/main/groovy/hr/mikrotron/poslotron/product/DeprecateSelectedProductsEvent.groovy"/>
        <response name="success" type="request-redirect" value="ProductDeprecation"/>
        <response name="error" type="view" value="ProductDeprecation"/>
    </request-map>

</site-conf>
