<!--
    Poslotron extensions for the Party Manager (partymgr) webapp controller.

    This file is included from
        applications/party/webapp/partymgr/WEB-INF/controller.xml
    via a single <include/> line, so that all our request- and view-maps
    extending the Party app live here in the plugin (not in core).
-->
<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Site-Conf"
        xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">

    <description>Poslotron extensions to Party Manager controller</description>

    <!-- ===== Suppliers ===== -->
    <request-map uri="findSuppliers">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="findSuppliers"/>
    </request-map>

    <view-map name="findSuppliers" type="screen"
              page="component://poslotron/widget/PartyAppExtScreens.xml#findSuppliers"/>

</site-conf>
