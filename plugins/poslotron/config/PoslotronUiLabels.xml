    <!-- ===== Batch add products (CSV) ===== -->
    <property key="PoslotronBatchAddProducts">
        <value xml:lang="en">Batch add products (CSV)</value>
        <value xml:lang="hr">Skupni unos proizvoda (CSV)</value>
    </property>
