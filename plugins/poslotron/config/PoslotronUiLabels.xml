    <property key="PoslotronOutOfStockProducts">
        <value xml:lang="en">Out of stock (QOH=0)</value>
        <value xml:lang="hr">Bez zalihe (QOH=0)</value>
    </property>
    <property key="PoslotronProductQuickAdd">
        <value xml:lang="en">Quick add product</value>
        <value xml:lang="hr">Brzi unos proizvoda</value>
