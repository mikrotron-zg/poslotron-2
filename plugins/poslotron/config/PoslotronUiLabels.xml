    <property key="PoslotronApplication">
        <value xml:lang="en">Poslotron Application</value>
        <value xml:lang="hr">Poslotron aplikacija</value>
    </property>
    <property key="PoslotronCompanyName">
        <value xml:lang="en">OFBiz: Poslotron</value>
        <value xml:lang="hr">OFBiz: Poslotron</value>
    </property>
    <property key="PoslotronCompanySubtitle">
        <value xml:lang="en">Part of the Apache OFBiz Family of Open Source Software</value>
        <value xml:lang="hr">Dio Apache OFBiz obitelji softvera otvorenog koda</value>
    </property>
    <property key="PoslotronViewPermissionError">
        <value xml:lang="en">You are not allowed to view this page.</value>
        <value xml:lang="hr">Nemate dopuštenje za pregled ove stranice.</value>
    </property>
    <property key="PoslotronPartySuppliers">
        <value xml:lang="en">Suppliers</value>
